    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.model_selection import GroupKFold\n",
    "from sklearn.multioutput import MultiOutputClassifier\n",
    "from lightgbm import LGBMClassifier\n",
    "from sklearn.metrics import classification_report\n",
    "import shap\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "def load_data(filepath):\n",
    "    df = pd.read_csv(\"full_data_unhealthy_imputed.csv\")\n",
    "    \n",
    "    print(\"Columns in raw data:\", df.columns.tolist())\n",
    "    \n",
    "    \n",
    "    column_map = {\n",
    "        'Cow': 'cow',\n",
    "        'Date': 'date',\n",
    "        'Hour': 'hour',\n",
    "        'IN ALLEYS': 'IN_ALLEYS',\n",
    "        'Activity Level': 'ACTIVITY_LEVEL'\n",
    "    }\n",
    "    df = df.rename(columns=column_map)\n",
    "    \n",
    "    required_cols = ['cow', 'date', 'hour', 'IN_ALLEYS', 'REST', 'EAT', 'ACTIVITY_LEVEL']\n",
    "    assert all(col in df.columns for col in required_cols), \\\n",
    "        f\"Missing columns. Current columns: {df.columns.tolist()}\"\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def engineer_features(df):\n",
    "    \"\"\"Create time-series and behavioral features with robust 0/0 handling\"\"\"\n",
    "    # Convert date and handle time\n",
    "    df['date'] = pd.to_datetime(df['date'])\n",
    "    df['day_of_week'] = df['date'].dt.dayofweek\n",
    "    df['is_weekend'] = df['day_of_week'].isin([5, 6]).astype(int)\n",
    "    \n",
    "    # Cyclical encoding for hour\n",
    "    df['hour_sin'] = np.sin(2 * np.pi * df['hour'] / 24)\n",
    "    df['hour_cos'] = np.cos(2 * np.pi * df['hour'] / 24)\n",
    "    \n",
    "    # Solution 1: Neutral value (1.0) when both REST and EAT are 0\n",
    "    df['rest_to_eat_ratio'] = np.where(\n",
    "        (df['EAT'] == 0) & (df['REST'] == 0),\n",
    "        1.0,  # Neutral value for 0/0 cases\n",
    "        df['REST'] / (df['EAT'] + 1e-6))  # Regular case (with epsilon to avoid div-by-zero)\n",
    "  \n",
    "    \n",
    "    # Solution 2: Flag zero-activity rows\n",
    "    df['zero_activity'] = ((df['EAT'] == 0) & (df['REST'] == 0)).astype(int)\n",
    "    \n",
    "    # Alternative feature: Total activity time\n",
    "    df['total_activity_time'] = df['REST'] + df['EAT']\n",
    "    \n",
    "    # Rolling features (per cow)\n",
    "    df.sort_values(['cow', 'date', 'hour'], inplace=True)\n",
    "    windows = {\n",
    "        '3h': 3,\n",
    "        '6h': 6,\n",
    "        '12h': 12\n",
    "    }\n",
    "    for name, window in windows.items():\n",
    "        df[f'rolling_activity_{name}'] = df.groupby('cow')['ACTIVITY_LEVEL'].transform(\n",
    "            lambda x: x.rolling(window).mean()\n",
    "        )\n",
    "        df[f'rolling_eat_{name}'] = df.groupby('cow')['EAT'].transform(\n",
    "            lambda x: x.rolling(window).sum()\n",
    "        )\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def train_model(X, y, groups):\n",
    "    \n",
    "    model = MultiOutputClassifier(\n",
    "        LGBMClassifier(\n",
    "            class_weight='balanced',\n",
    "            random_state=42,\n",
    "            n_estimators=200,\n",
    "            max_depth=5,\n",
    "            learning_rate=0.05\n",
    "        )\n",
    "    )\n",
    "    \n",
    "    # Cross-validation\n",
    "    gkf = GroupKFold(n_splits=3)\n",
    "    results = []\n",
    "    \n",
    "    for fold, (train_idx, test_idx) in enumerate(gkf.split(X, y, groups)):\n",
    "        X_train, X_test = X.iloc[train_idx], X.iloc[test_idx]\n",
    "        y_train, y_test = y.iloc[train_idx], y.iloc[test_idx]\n",
    "        \n",
    "        model.fit(X_train, y_train)\n",
    "        y_pred = model.predict(X_test)\n",
    "        \n",
    "        # Store fold results\n",
    "        fold_results = {}\n",
    "        for i, disease in enumerate(targets):\n",
    "            report = classification_report(\n",
    "                y_test.iloc[:, i], \n",
    "                y_pred[:, i], \n",
    "                output_dict=True\n",
    "            )\n",
    "            fold_results[disease] = {\n",
    "                'precision': report['weighted avg']['precision'],\n",
    "                'recall': report['weighted avg']['recall'],\n",
    "                'f1': report['weighted avg']['f1-score']\n",
    "            }\n",
    "        results.append(fold_results)\n",
    "    \n",
    "    return model, results\n",
    "\n",
    "\n",
    "def explain_model(model, X_test, features, targets):\n",
    "    \"\"\"Generate SHAP explanations for each disease\"\"\"\n",
    "    plt.figure(figsize=(15, 20))\n",
    "    \n",
    "    for i, disease in enumerate(targets):\n",
    "        # Get the underlying LGBM model\n",
    "        lgb_model = model.estimators_[i]\n",
    "        \n",
    "        # Compute SHAP values\n",
    "        explainer = shap.TreeExplainer(lgb_model)\n",
    "        shap_values = explainer.shap_values(X_test)\n",
    "        \n",
    "        # Plot\n",
    "        plt.subplot(len(targets), 1, i+1)\n",
    "        shap.summary_plot(\n",
    "            shap_values, \n",
    "            X_test, \n",
    "            feature_names=features,\n",
    "            show=False,\n",
    "            plot_type='bar'\n",
    "        )\n",
    "        plt.title(f'SHAP Analysis - {disease}')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('shap_summary.png')\n",
    "    plt.close()\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    # Load data\n",
    "    data = load_data('cattle_data.csv')  # Replace with your file\n",
    "    \n",
    "    # Engineer features (with 0/0 handling)\n",
    "    data = engineer_features(data)\n",
    "    \n",
    "    # Check zero-activity rows\n",
    "    zero_activity_rows = data[(data['EAT'] == 0) & (data['REST'] == 0)]\n",
    "    print(f\"\\nRows with 0 EAT and 0 REST: {len(zero_activity_rows)}\")\n",
    "    if len(zero_activity_rows) > 0:\n",
    "        print(\"Sample of zero-activity rows:\")\n",
    "        print(zero_activity_rows[['cow', 'date', 'hour', 'REST', 'EAT']].head())\n",
    "    \n",
    "    # Define targets and features\n",
    "    targets = ['oestrus', 'calving', 'lameness', 'mastitis']\n",
    "    features = [\n",
    "        'IN_ALLEYS', 'REST', 'EAT', 'ACTIVITY_LEVEL',\n",
    "        'rest_to_eat_ratio', 'zero_activity', 'total_activity_time',\n",
    "        'rolling_activity_3h', 'rolling_activity_6h', 'rolling_activity_12h',\n",
    "        'rolling_eat_3h', 'rolling_eat_6h', 'rolling_eat_12h',\n",
    "        'hour_sin', 'hour_cos', 'is_weekend'\n",
    "    ]\n",
    "    \n",
    "    # Prepare data\n",
    "    X = data[features]\n",
    "    y = data[targets]\n",
    "    groups = data['cow']\n",
    "    \n",
    "    # Train model\n",
    "    model, cv_results = train_model(X, y, groups)\n",
    "    \n",
    "    # Print CV results\n",
    "    print(\"\\nCross-Validation Results:\")\n",
    "    for fold, res in enumerate(cv_results):\n",
    "        print(f\"\\nFold {fold + 1}:\")\n",
    "        for disease, metrics in res.items():\n",
    "            print(f\"{disease}: P={metrics['precision']:.2f}, R={metrics['recall']:.2f}, F1={metrics['f1']:.2f}\")\n",
    "    \n",
    "    # SHAP Analysis (on last test set)\n",
    "    print(\"\\nGenerating SHAP explanations...\")\n",
    "    _, test_idx = next(GroupKFold(n_splits=3).split(X, y, groups))\n",
    "    X_test = X.iloc[test_idx]\n",
    "    explain_model(model, X_test, features, targets)\n",
    "    \n",
    "    print(\"\\nDone! SHAP plots saved to 'shap_summary.png'\")"
   ]
